{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(pages|logos)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(cover-art\\.webp|favicon\\.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
